{
  "manifest_version": 3,
  "name": "Gmail Quote Selected",
  "version": "3.0",
  "description": "Right-click or use a shortcut to reply with quoted text in Gmail.",
  "permissions": ["contextMenus", "scripting", "activeTab", "storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "run-quote-reply": {
      "suggested_key": {
        "default": "Alt+Q",
        "mac": "MacCtrl+Q"
      },
      "description": "Trigger Reply All with Quoted Text"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Gmail Quote Selected"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["inboxsdk.js", "elm-content.js", "content_init.js"]
    }
  ]
}
